<?xml version="1.0" encoding="UTF-8"?>

<!DOCTYPE hibernate-configuration PUBLIC
	"-//Hibernate/Hibernate Configuration DTD 3.0//EN"
	"http://www.hibernate.org/dtd/hibernate-configuration-3.0.dtd">
	
<hibernate-configuration>
	<session-factory>
	
	<!--database configuration-->
		<property name="hibernate.connection.url">jdbc:mysql://localhost:3306/hiber
		</property>
		<property name="hibernate.connection.username"> root
		</property>
		<property name="hibernate.connection.password"> Shivam@2365
		</property>
		<property name="hibernate.connection.driver_class"> com.mysql.cj.jdbc.Driver
		</property>
		
	<!--hibernate configuration-->
		<property name="hibernate.dialect"> org.hibernate.dialect.MySQLDialect</property>
		<property name="hibernate.show_sql"> true</property>
		<property name="hibernate.format_sql"> true</property>
		<property name="hibernate.hbm2ddl.auto"> update</property>
		
	<!-- Xml/ class mapping-->

		<mapping class="com.lcwd.hiber.entities.Student"/>
		<mapping class="com.lcwd.hiber.entities.Certificates"/>
	</session-factory>
</hibernate-configuration>